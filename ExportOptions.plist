<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- "development" preserves get-task-allow:true so LLDB can attach.     -->
	<!-- Do NOT change to "ad-hoc" or "app-store" — that strips the          -->
	<!-- entitlement and breaks the Chapter 1 challenge.                      -->
	<key>method</key>
	<string>development</string>

	<key>teamID</key>
	<string>TEAM_ID_PLACEHOLDER</string>

	<key>signingStyle</key>
	<string>manual</string>

	<key>signingCertificate</key>
	<string>Apple Development</string>

	<!-- Include all architectures so the IPA works on any supported device. -->
	<key>thinning</key>
	<string>&lt;none&gt;</string>

	<key>compileBitcode</key>
	<false/>
</dict>
</plist>
